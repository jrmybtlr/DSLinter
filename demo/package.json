{
  "name": "dslint-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite-only": "vite",
    "dev:watch": "concurrently --names vite,dslint --prefix-colors blue,green \"vite\" \"npm run dslint:watch\"",
    "dev:serve": "concurrently --names dslint,vite --prefix-colors green,blue \"npm run dslint:serve\" \"wait-on tcp:127.0.0.1:7878 && vite --mode serve\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dslint:report": "node scripts/gen-dslint-report.mjs",
    "dslint:merge-playgrounds": "node scripts/merge-playgrounds.mjs",
    "dslint:watch": "node scripts/run-dslint.mjs . --watch --output public/dslint-report.json",
    "dslint:serve": "node scripts/run-dslint.mjs . --serve 7878 --output public/dslint-report.json",
    "dslint:print-cmd": "node scripts/run-dslint.mjs --print-cmd . --serve 7878 --output public/dslint-report.json"
  },
  "dependencies": {
    "dslinter": "file:../packages/dashboard",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
