{
  "name": "dslinter-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite-only": "vite",
    "dev:watch": "node ../packages/dashboard/bin/dslinter.mjs --watch --output public/dslinter-report.json",
    "dev:serve": "node ../packages/dashboard/bin/dslinter.mjs --serve 7878 --output public/dslinter-report.json",
    "build": "tsc && node ../packages/dashboard/bin/dslinter.mjs --build --output public/dslinter-report.json",
    "preview": "vite preview",
    "dslinter:report": "node scripts/gen-dslinter-report.mjs",
    "dslinter:merge-playgrounds": "node scripts/merge-playgrounds.mjs",
    "dslinter:watch": "node ../packages/dashboard/bin/dslinter.mjs --watch --output public/dslinter-report.json",
    "dslinter:serve": "node ../packages/dashboard/bin/dslinter.mjs --serve 7878 --output public/dslinter-report.json"
  },
  "dependencies": {
    "dslinter": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.6.3",
    "vite": "^7.3.5"
  }
}
