{
  "name": "dslinter-monorepo",
  "private": true,
  "workspaces": [
    "demo/inertia",
    "demo/react",
    "dashboard"
  ],
  "scripts": {
    "fmt": "oxfmt demo/react demo/inertia dashboard",
    "fmt:check": "oxfmt --check demo/react demo/inertia dashboard",
    "lint": "oxlint --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/dashboard-dist/**\" demo/react demo/inertia dashboard",
    "lint:fix": "oxlint --fix --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/dashboard-dist/**\" demo/react demo/inertia dashboard",
    "build:napi": "pnpm --filter dslinter run build:napi",
    "test": "cargo test && pnpm run build:napi && pnpm run lint && pnpm --filter dslinter test && node dashboard/bin/dslinter.mjs --version && pnpm --filter dslinter-demo run build",
    "release:major": "node scripts/release.mjs --major",
    "release:minor": "node scripts/release.mjs --minor",
    "release:patch": "node scripts/release.mjs --patch"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "changelogen": "^0.6.2",
    "semver": "^7.8.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "qs": "6.15.2",
    "shell-quote": "1.8.4",
    "hono": "4.12.25",
    "undici": "7.28.0",
    "ws": "8.21.0",
    "form-data": "4.0.6"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "qs": "6.15.2",
      "shell-quote": "1.8.4",
      "hono": "4.12.25",
      "undici": "7.28.0",
      "ws": "8.21.0",
      "form-data": "4.0.6"
    },
    "publicHoistPattern": ["*react", "*react-dom"]
  }
}
