{
  "name": "dslinter",
  "private": true,
  "workspaces": [
    "demo",
    "packages/dashboard"
  ],
  "scripts": {
    "fmt": "oxfmt demo packages/dashboard",
    "fmt:check": "oxfmt --check demo packages/dashboard",
    "lint": "oxlint --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/dashboard-dist/**\" demo packages/dashboard",
    "lint:fix": "oxlint --fix --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/dashboard-dist/**\" demo packages/dashboard",
    "build:napi": "pnpm --filter dslinter run build:napi",
    "test": "cargo test && pnpm run build:napi && pnpm run lint && pnpm --filter dslinter test && node packages/dashboard/bin/dslinter.mjs --version && pnpm --filter dslint-demo run build",
    "release:major": "node scripts/release.mjs --major",
    "release:minor": "node scripts/release.mjs --minor",
    "release:patch": "node scripts/release.mjs --patch"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.0",
    "changelogen": "^0.6.2",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.6",
      "react-dom": "19.2.6"
    },
    "publicHoistPattern": ["*react", "*react-dom"]
  }
}
