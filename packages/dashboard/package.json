{
  "name": "@dslinter/dashboard",
  "version": "0.0.3",
  "description": "DSLinter dashboard UI: playground shell, token wall, and governance panels (consumes dslint-report.json).",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrmybtlr/DSLint.git",
    "directory": "packages/dashboard"
  },
  "bugs": {
    "url": "https://github.com/jrmybtlr/DSLint/issues"
  },
  "homepage": "https://github.com/jrmybtlr/DSLint#readme",
  "keywords": [
    "dslinter",
    "design-system",
    "react",
    "tailwind",
    "tailwindcss",
    "dashboard",
    "governance",
    "tokens",
    "shadcn"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "prepublishOnly": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme.css": "./src/styles/dashboard-theme.css"
  },
  "types": "./src/index.ts",
  "files": [
    "src",
    "components.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@shikijs/twoslash": "^4.0.2",
    "@shikijs/types": "^4.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.7.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "twoslash-cdn": "^0.3.8",
    "usemods": "^1.16.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  }
}
