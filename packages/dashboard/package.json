{
  "name": "dslinter",
  "version": "0.1.1",
  "description": "DSLinter dashboard UI: playground shell, token wall, and governance panels (consumes dslint-report.json).",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrmybtlr/DSLinter.git",
    "directory": "packages/dashboard"
  },
  "bugs": {
    "url": "https://github.com/jrmybtlr/DSLinter/issues"
  },
  "homepage": "https://github.com/jrmybtlr/DSLinter#readme",
  "keywords": [
    "dslinter",
    "design-system",
    "react",
    "tailwind",
    "tailwindcss",
    "dashboard",
    "governance",
    "tokens",
    "shadcn"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "dslinter": "bin/dslinter.mjs"
  },
  "scripts": {
    "build:napi": "napi build --platform --release --cwd ../.. --output-dir packages/dashboard --package-json-path packages/dashboard/package.json --js-package-name @dslinter/binding --js index.cjs --no-default-features --features napi",
    "build:dashboard": "vite build",
    "artifacts": "napi artifacts --cwd ../.. --package-json-path packages/dashboard/package.json --js-package-name @dslinter/binding",
    "test": "vitest run",
    "prepublishOnly": "vitest run && vite build"
  },
  "napi": {
    "binaryName": "dslinter",
    "packageName": "@dslinter/binding",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ],
    "flags": [
      "--no-default-features",
      "--features",
      "napi"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme.css": "./src/styles/dashboard-theme.css"
  },
  "types": "./src/index.ts",
  "files": [
    "bin",
    "dashboard-dist",
    "index.cjs",
    "index.d.ts",
    "src",
    "components.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@shikijs/twoslash": "^4.0.2",
    "@shikijs/types": "^4.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.7.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "twoslash-cdn": "^0.3.8",
    "usemods": "^1.16.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.1.0",
    "typescript": "~6.0.3",
    "vite": "^7.3.3",
    "vitest": "^3.2.4"
  }
}
